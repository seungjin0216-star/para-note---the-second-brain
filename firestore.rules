rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 사용자 본인 데이터만 접근 가능
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 다른 경로는 전면 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
